<%- layout('superadmin/layout/main') %>
<%- block('title').append('Create Product') %>

<% block('style').append(`
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<style>
</style>
`) %>

<div class="container mt-2 col-12">



    <!-- Row 1: Product -->
  <div class="row mb-2 border-bottom py-2">
    <div class="col-md-4 d-flex align-items-center justify-content-start">
      <h5 class="mb-2"><i class="fas fa-plus"></i> Product</h5>
    </div>

    <div class="col-md-3 d-flex align-items-center">
      <a href="/superadmin/prods/view<%= catid ? '/' + catid : '' %><%= subcatid ? '/' + subcatid : '' %>" 
        class="btn btn-sm btn-success ms-2">
        <i class="fas fa-eye"></i> Products
      </a>
    </div>
  </div>

  <!-- Row 2: Subcategories + Categories -->
  <div class="row mb-2 border-bottom py-2">
    <div class="col-md-3 d-flex align-items-center">
      <a href="/superadmin/subcats/view<%= catid ? '/' + catid : '' %>" 
        class="btn btn-sm btn-info fw-bold">
        <i class="fas fa-eye"></i> Subcategories
      </a>
    </div>

    <div class="col-md-3 d-flex align-items-center">
      <a href="/superadmin/subcats/create<%= catid ? '/' + catid : '' %>" 
        class="btn btn-sm btn-success ms-2">
        <i class="fas fa-plus"></i> Subcategory
      </a>
    </div>

    <div class="col-md-3 d-flex align-items-center">
      <a href="/superadmin/cats/view" 
        class="btn btn-sm btn-info fw-bold">
        <i class="fas fa-eye"></i> Categories
      </a>
    </div>

    <div class="col-md-3 d-flex align-items-center">
      <a href="/superadmin/cats/create" 
        class="btn btn-sm btn-success ms-2">
        <i class="fas fa-plus"></i> Category
      </a>
    </div>
  </div>



  <% if (success.length > 0) { %>
    <div class="alert alert-success" style="white-space: pre-line;"><%= success %></div>
  <% } %>
  <% if (error.length > 0) { %>
    <div class="alert alert-danger" style="white-space: pre-line;"><%= error %></div>
  <% } %>

  <form action="/superadmin/prods/store" method="POST" enctype="multipart/form-data">

    <!-- Category -->
    <div class="mb-3">
      <label for="catid" class="form-label">Select Category</label>
      <select id="catid" name="catid" class="form-select" required>
        <option value="">-- Select Category --</option>
      </select>
    </div>

    <!-- Subcategory -->
    <div class="mb-3">
      <label for="subcatid" class="form-label">Select Subcategory</label>
      <select id="subcatid" name="subcatid" class="form-select" required>
        <option value="">-- Select Subcategory --</option>
      </select>
    </div>

    <!-- Product Name -->
    <div class="mb-3">
      <label for="name" class="form-label">Product Name</label>
      <input type="text" id="name" name="name" class="form-control" required>
      <div id="nameFeedback" class="form-text text-danger"></div>
    </div>

    <!-- Description -->
    <div class="mb-3">
      <label for="description" class="form-label">Description</label>
      <textarea id="description" name="des" class="form-control" rows="3"></textarea>
    </div>

    <!-- Details -->
    <div class="mb-3">
      <label for="details" class="form-label">Details</label>
      <textarea id="details" name="dess" class="form-control" rows="5"></textarea>
    </div>

    <!-- Image Upload -->
    <div class="mb-3">
      <label for="img" class="form-label">Upload Image</label>
      <input type="file" id="img" name="img" accept="image/*" class="form-control">
      <div id="preview" class="mt-2">
        <img id="previewImg" src="" alt="Preview" class="img-thumbnail" style="max-width:200px; display:none;">
      </div>
    </div>

    <!-- Document Upload -->
    <div class="mb-3">
      <label for="document" class="form-label">Upload Document</label>
      <input type="file" id="document" name="document" accept=".pdf,.doc,.docx,.txt,image/*" class="form-control">
    </div>

    <div class="d-flex justify-content-end">
      <button type="submit" id="addrecord" class="btn btn-primary" disabled>Save</button>
    </div>
  </form>
</div>

<%- include('script/add') %>

<% block('script').append(`
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"><\/script>
<script>
  $(document).ready(function () {
    $('#catid').select2();
    $('#subcatid').select2();
  });
<\/script>
`) %>
