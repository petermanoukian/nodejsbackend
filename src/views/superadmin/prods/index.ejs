<%- layout('superadmin/layout/main') %>
<%- block('title').append('Products') %>

<% block('style').append(`
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<style>
</style>
`) %>

<div class="container mt-2 col-12 mb-2">
  <!-- Row 1: Products -->
  <div class="row mb-3 border-bottom py-2">
    <div class="col-md-4 d-flex align-items-center justify-content-start">
      <h4 class="mb-2">Products</h4>
    </div>
  </div>

  <!-- Row 2: Subcategories + Categories -->
  <div class="row mb-2 border-bottom py-2">


    <div class="col-md-2 d-flex align-items-center">
      <a href="/superadmin/prods/create<%= catid ? '/' + catid : '' %><%= subcatid ? '/' + subcatid : '' %>" 
        class="btn btn-sm btn-success ms-2">
        <i class="fas fa-plus"></i> Product
      </a>
    </div>


    <div class="col-md-2 d-flex align-items-center">
      <a href="/superadmin/subcats/view<%= catid ? '/' + catid : '' %>" 
        class="btn btn-sm btn-info fw-bold">
        <i class="fas fa-eye"></i> Subcategories
      </a>
    </div>

    <div class="col-md-2 d-flex align-items-center">
      <a href="/superadmin/subcats/create<%= catid ? '/' + catid : '' %>" 
        class="btn btn-sm btn-success ms-2">
        <i class="fas fa-plus"></i> Subcategory
      </a>
    </div>

    <div class="col-md-2 d-flex align-items-center">
      <a href="/superadmin/cats/view" 
        class="btn btn-sm btn-info fw-bold">
        <i class="fas fa-eye"></i> Categories
      </a>
    </div>

    <div class="col-md-2 d-flex align-items-center">
      <a href="/superadmin/cats/create" 
        class="btn btn-sm btn-success ms-2">
        <i class="fas fa-plus"></i> Category
      </a>
    </div>
  </div>

  <% if (success.length > 0) { %>
    <div class="alert alert-success" style="white-space: pre-line;"><%= success %></div>
  <% } %>
  <% if (error.length > 0) { %>
    <div class="alert alert-danger" style="white-space: pre-line;"><%= error %></div>
  <% } %>

  <% if (rowCount > 0) { %>
  <div class="row mb-2">
    <div class="col-md-4">
      <input type="text" id="searchInput" 
             class="form-control maxwidth300" placeholder="Search...">
    </div>

    <!-- Category dropdown -->
    <div class="col-md-4">
      <select id="catid" class="form-select">
        <option value="">-- All Categories --</option>
        <% categories.forEach(cat => { %>
          <option value="<%= cat.id %>" <%= catid == cat.id ? 'selected' : '' %>>
            <%= cat.name %>
          </option>
        <% }) %>
      </select>
    </div>

    <!-- Subcategory dropdown -->
    <div class="col-md-4">
      <select  id="subcatSelect" class="form-select">
        <option value="">-- All Subcategories --</option>
        <!-- JS will populate based on selected category -->
      </select>
    </div>

  </div>

  <!-- Table -->
  <table id="dataTable" class="table table-striped table-bordered">
    <thead>
      <tr>
        <th>
          <input type="checkbox" id="selectAll">
          <button id="inverseSelection" 
                  class="btn btn-sm btn-secondary ms-2 inverse-btn" 
                  data-bs-toggle="tooltip" 
                  data-bs-placement="top" 
                  title="Inverse Selection">
            <i class="fas fa-random"></i>
          </button>
        </th>
        <th data-field="id">ID <span class="arrow cursor">⇅</span></th>
        <th data-field="name">Name <span class="arrow cursor">⇅</span></th>
        <th data-field="catid">Category <span class="arrow cursor">⇅</span></th>
        <th data-field="subcatid">Subcategory <span class="arrow cursor">⇅</span></th>
        <th data-field="document">File</th>
        <th data-field="img">Image</th>
        <th data-field="createdAt">Created At</th>
        <th data-field="action">Actions</th>
      </tr>
    </thead>
    <tbody>
      <!-- rows injected via JS -->
    </tbody>
  </table>

  <div class="d-flex justify-content-center mb-2">
    <button id="bulkDeleteBtn" class="btn btn-danger" style="display:none;">
      Bulk Delete
    </button>
  </div>

  <nav>
    <ul id="pagination" class="pagination justify-content-center"></ul>
  </nav>
  <% } else { %>
    <div class="d-flex justify-content-center mb-2">
      NO RECORDS
    </div>
  <% } %>
</div>

<%- include('script/view') %>

<% block('script').append(`
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"><\/script>
<script>
  document.addEventListener("DOMContentLoaded", function () {
    $('#catid').select2();
    $('#subcatSelect').select2();

    const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
    tooltipTriggerList.forEach(function (tooltipTriggerEl) {
      new bootstrap.Tooltip(tooltipTriggerEl);
    });
  });
<\/script>
`) %>
